class Solution {
    public int majorityElement(int[] arr) {
        int count = 0;
        int ans = 0;
        for(int i=0; i<arr.length; i++){
            if(count == 0){
                ans = arr[i];
            }
            if(ans == arr[i]){
                count++;
            }else{
                count--;
            }
        }
        return ans;
    }
}
